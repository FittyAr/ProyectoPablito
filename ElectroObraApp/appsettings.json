{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ElectroObraApp.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Application": {
    "Name": "ElectroObraApp",
    "DefaultLanguage": "es",
    "SeedEnabled": true,
    "Email": {
      "PreferredClient": "SystemDefault",
      "GmailUrl": "https://mail.google.com/mail/u/0/?view=cm&fs=1&to={email}",
      "OutlookUrl": "https://outlook.live.com/mail/0/deeplink/compose?to={email}",
      "YahooUrl": "https://mail.yahoo.com/d/compose-message?to={email}"
    },
    "Branding": {
      "LogoPath": "avares://ElectroObraApp/Assets/Images/electro-obra.png",
      "BackgroundPath": "avares://ElectroObraApp/Assets/Images/electro-obra3.png"
    },
    "Settlement": {
      "MultiplierSaturday": "1.5",
      "MultiplierSunday": "2.0",
      "MultiplierHoliday": "2.0",
      "IncludeSaturday": false,
      "IncludeSunday": false,
      "IncludeHoliday": false,
      "HolidayApiUrl": "https://api.argentinadatos.com/v1/feriados/",
      "DollarApiUrl": "https://dolarapi.com/v1/dolares"
    }
  }
}