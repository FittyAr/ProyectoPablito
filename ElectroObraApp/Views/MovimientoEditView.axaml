<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="550"
             x:Class="ElectroObraApp.Views.MovimientoEditView"
             x:DataType="vm:MovimientoEditViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.KeyBindings>
    <Border Padding="25" Background="#2d2d2d" CornerRadius="12" BoxShadow="0 4 10 0 #40000000" Width="600">
        <ScrollViewer MaxHeight="700">
            <StackPanel Spacing="18" Margin="0,0,15,0">
                <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,5" Foreground="White"/>
            
            <StackPanel Spacing="5">
                <TextBlock Text="Concepto" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                <TextBox Text="{Binding Movimiento.Concepto}" PlaceholderText="Ej: Pago de materiales eléctricos"/>
            </StackPanel>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="20" RowDefinitions="Auto, Auto, Auto" RowSpacing="15">
                <!-- Fila 1: Monto y Cantidad -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Monto Unitario" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <NumericUpDown Value="{Binding Movimiento.Monto}" FormatString="C2" HorizontalAlignment="Stretch"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Cantidad" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <NumericUpDown Value="{Binding Movimiento.Cantidad}" Minimum="1" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- Fila 2: Tipo y Categoría -->
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Tipo" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <ComboBox ItemsSource="{Binding TiposMovimiento}" 
                              SelectedValue="{Binding Movimiento.TipoMovimientoId}"
                              SelectedValueBinding="{Binding Id}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Categoría" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <ComboBox ItemsSource="{Binding Categorias}" 
                              SelectedValue="{Binding Movimiento.CategoriaId}"
                              SelectedValueBinding="{Binding Id}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Fila 3: Empleado y Fecha -->
                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Empleado (Opcional)" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <ComboBox ItemsSource="{Binding Empleados}" 
                              SelectedValue="{Binding Movimiento.EmpleadoId}"
                              SelectedValueBinding="{Binding Id}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Fecha" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <CalendarDatePicker SelectedDate="{Binding FechaProxy}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,10,0,0">
                <Button Content="Cancelar" Command="{Binding CancelCommand}" IsCancel="True" Padding="20,0"/>
                <Button Content="Guardar" Classes="accent" Command="{Binding SaveCommand}" IsDefault="True" Padding="20,0"/>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

