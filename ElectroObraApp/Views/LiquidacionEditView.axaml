<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
             x:Class="ElectroObraApp.Views.LiquidacionEditView"
             x:DataType="vm:LiquidacionEditViewModel">
    <Border Padding="20" Background="#2d2d2d" CornerRadius="8">
        <StackPanel Spacing="15">
            <TextBlock Text="Generar Nueva Liquidación" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Spacing="5">
                <TextBlock Text="Empleado" FontSize="12" Foreground="#aaa"/>
                <ComboBox ItemsSource="{Binding Empleados}" 
                          SelectedValue="{Binding Liquidacion.EmpleadoId}"
                          SelectedValueBinding="{Binding Id}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nombre}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,5,0">
                    <TextBlock Text="Fecha Inicio" FontSize="12" Foreground="#aaa"/>
                    <DatePicker SelectedDate="{Binding FechaInicioOffset}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5" Margin="5,0,0,0">
                    <TextBlock Text="Fecha Fin" FontSize="12" Foreground="#aaa"/>
                    <DatePicker SelectedDate="{Binding FechaFinOffset}"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="5">
                <TextBlock Text="Días Trabajados" FontSize="12" Foreground="#aaa"/>
                <NumericUpDown Value="{Binding Liquidacion.DiasTrabajados}" Minimum="0" Maximum="31"/>
            </StackPanel>

            <Expander Header="Configuración de Días Especiales" HorizontalAlignment="Stretch" Margin="0,5">
                <StackPanel Spacing="10" Margin="5">
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <CheckBox Grid.Column="0" Content="Incluir Sábados" IsChecked="{Binding IncluirSabados}"/>
                        <TextBlock Grid.Column="1" Text="x" VerticalAlignment="Center" Margin="10,0"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding Liquidacion.MultiplicadorSabado}" Increment="0.1" Minimum="0" FormatString="0.0" Width="100"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <CheckBox Grid.Column="0" Content="Incluir Domingos" IsChecked="{Binding IncluirDomingos}"/>
                        <TextBlock Grid.Column="1" Text="x" VerticalAlignment="Center" Margin="10,0"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding Liquidacion.MultiplicadorDomingo}" Increment="0.1" Minimum="0" FormatString="0.0" Width="100"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <CheckBox Grid.Column="0" Content="Incluir Feriados" IsChecked="{Binding IncluirFeriados}"/>
                        <TextBlock Grid.Column="1" Text="x" VerticalAlignment="Center" Margin="10,0"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding Liquidacion.MultiplicadorFeriado}" Increment="0.1" Minimum="0" FormatString="0.0" Width="100"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <Button Content="Sugerir Liquidación (Calcular Adelantos)" 
                    Command="{Binding SugerirCommand}" 
                    HorizontalAlignment="Stretch" Classes="outline"/>

            <Separator Background="#444"/>

            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Bruto:"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Liquidacion.TotalBruto, StringFormat=C2}" Foreground="White"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Adelantos (Descuento):" Foreground="Red"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Liquidacion.TotalAdelantos, StringFormat=C2}" Foreground="Red"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="NETO A PAGAR:" FontWeight="Bold" FontSize="18"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Liquidacion.TotalNeto, StringFormat=C2}" FontWeight="Bold" FontSize="18" Foreground="Green"/>
            </Grid>

            <StackPanel Spacing="5">
                <TextBlock Text="Observaciones" FontSize="12" Foreground="#aaa"/>
                <TextBox Text="{Binding Liquidacion.Observaciones}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Cancelar" Command="{Binding CancelCommand}" IsCancel="True" />
                <Button Content="Confirmar y Guardar" Classes="accent" Command="{Binding SaveCommand}" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

