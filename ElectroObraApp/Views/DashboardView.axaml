<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             xmlns:dto="clr-namespace:ElectroObraApp.Application.DTOs;assembly=ElectroObraApp.Application"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="using:ElectroObraApp.Views.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="1200"
             x:Class="ElectroObraApp.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    
    <UserControl.Resources>
        <conv:BoolToObjectConverter x:Key="BoolToTextConverter" TrueValue="Modo Privado" FalseValue="Modo Público" />
        <conv:BoolToObjectConverter x:Key="BoolToIconConverter" TrueValue="EyeOff" FalseValue="Eye" />
        <conv:BoolToObjectConverter x:Key="BoolToColorConverter" TrueValue="#ff5252" FalseValue="#4caf50" />
    </UserControl.Resources>

    <ScrollViewer>
        <Grid RowDefinitions="Auto, Auto, Auto, *, *, *" Margin="25">
            <!-- Header & Controls -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,20">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="{Binding Title}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Vista general del estado operativo" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14"/>
                </StackPanel>

                <!-- Period Selector -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Periodo:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    <ComboBox ItemsSource="{Binding TimeRanges}" 
                              SelectedItem="{Binding CurrentTimeRange}" 
                              Width="120" />
                </StackPanel>

                <!-- Modern Privacy Toggle (Icon Only) -->
                <ToggleButton Grid.Column="2" 
                              IsChecked="{Binding IsPrivacyModeActive}"
                              Classes="privacyButton"
                              ToolTip.Tip="Alternar Modo Privado (Ocultar montos)">
                    <materialIcons:MaterialIcon Kind="{Binding IsPrivacyModeActive, Converter={StaticResource BoolToIconConverter}}" 
                                                Width="24" Height="24"
                                                Foreground="{Binding IsPrivacyModeActive, Converter={StaticResource BoolToColorConverter}}" />
                </ToggleButton>
            </Grid>

            <!-- Dollar Rates Banner -->
            <Border Grid.Row="1" IsVisible="{Binding ShowDollarRates}" 
                    Background="{DynamicResource SidebarBackgroundBrush}" 
                    CornerRadius="15" Margin="0,0,0,20" Padding="15,10">
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <materialIcons:MaterialIcon Kind="CurrencyUsd" Foreground="#ff9800" Width="20" Height="20"/>
                        <TextBlock Text="Cotización Dólar" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource MainForegroundBrush}"/>
                    </StackPanel>
                    
                    <ItemsControl ItemsSource="{Binding DollarRates}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="25"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:DollarDto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="C:" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                        <TextBlock Text="{Binding Compra, StringFormat=\{0:C\}}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#4caf50"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="V:" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                        <TextBlock Text="{Binding Venta, StringFormat=\{0:C\}}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#ff5252"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Top Metrics Row -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
                <Border Classes="card metricCard" Background="#1b3a1b" BorderBrush="#4caf50">
                    <StackPanel>
                        <TextBlock Text="Ingresos" Classes="cardLabel" Foreground="#aaa"/>
                        <TextBlock Text="{Binding DisplayTotalIngresos}" Classes="cardValue" Foreground="#4caf50"/>
                    </StackPanel>
                </Border>

                <Border Classes="card metricCard" Background="#3a1b1b" BorderBrush="#f44336">
                    <StackPanel>
                        <TextBlock Text="Gastos" Classes="cardLabel" Foreground="#aaa"/>
                        <TextBlock Text="{Binding DisplayTotalGastos}" Classes="cardValue" Foreground="#f44336"/>
                    </StackPanel>
                </Border>

                <Border Classes="card metricCard" Background="#1b1b3a" BorderBrush="#2196f3">
                    <StackPanel>
                        <TextBlock Text="Balance" Classes="cardLabel" Foreground="#aaa"/>
                        <TextBlock Text="{Binding DisplayBalance}" Classes="cardValue" Foreground="#2196f3"/>
                    </StackPanel>
                </Border>

                <Border Classes="card metricCard" Background="{DynamicResource PaneBackgroundBrush}" BorderBrush="#ff9800">
                    <StackPanel>
                        <TextBlock Text="Pendientes" Classes="cardLabel" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding TrabajosPendientes}" Classes="cardValue" Foreground="#ff9800"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Main Charts Row -->
            <Grid Grid.Row="3" ColumnDefinitions="2*, *" Margin="0,0,0,20">
                <Border Classes="chartCard" Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Evolución Financiera" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <lvc:CartesianChart Series="{Binding Series}" 
                                            XAxes="{Binding XAxes}" 
                                            Height="350"
                                            Background="Transparent"
                                            TooltipPosition="{Binding ChartTooltipPosition}"/>
                    </StackPanel>
                </Border>

                <Border Classes="chartCard" Grid.Column="1" Margin="10,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Distribución" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <lvc:PieChart Series="{Binding CategorySeries}" 
                                      Height="350" 
                                      Background="Transparent"
                                      TooltipPosition="{Binding PieTooltipPosition}"
                                      LegendPosition="Bottom"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Intelligence Row -->
            <Grid Grid.Row="4" ColumnDefinitions="*, *, *" Margin="0,0,0,20">
                <!-- Top Clientes -->
                <Border Classes="chartCard" Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Spacing="15">
                        <TextBlock Text="💎 Top Clientes" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <ItemsControl ItemsSource="{Binding TopClientes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TopClienteDto">
                                    <Border Background="#10888888" Margin="0,0,0,8" Padding="12" CornerRadius="10">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="Medium" Foreground="{DynamicResource MainForegroundBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat=\{0:C\}}" Foreground="#4caf50" FontWeight="Bold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recent Activity -->
                <Border Classes="chartCard" Grid.Column="1" Margin="10,0,10,0">
                    <StackPanel Spacing="15">
                        <TextBlock Text="🕒 Actividad Reciente" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <ItemsControl ItemsSource="{Binding RecentMovimientos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="dto:MovimientoDto">
                                    <Border BorderBrush="#20888888" BorderThickness="0,0,0,1" Padding="0,5,0,5">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <TextBlock Text="{Binding Fecha, StringFormat=\{0:dd/MM\}}" Foreground="{DynamicResource SecondaryForegroundBrush}" Width="40"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Concepto}" Foreground="{DynamicResource MainForegroundBrush}" TextTrimming="CharacterEllipsis" Margin="5,0"/>
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding Total, StringFormat=\{0:C\}}" 
                                                       Foreground="{Binding TipoMovimientoSuma, Converter={StaticResource BoolToColorConverter}}"
                                                       FontWeight="Bold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Notifications & Health -->
                <Border Classes="chartCard" Grid.Column="2" Margin="10,0,0,0">
                    <StackPanel Spacing="15">
                        <TextBlock Text="📢 Alertas" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <Button Classes="alertButton" Command="{Binding NavigateToAlertCommand}" CommandParameter="Liquidaciones">
                            <Border Background="#20ff9800" Padding="12" CornerRadius="10" BorderBrush="#ff9800" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="⚠️" VerticalAlignment="Center"/>
                                    <TextBlock Text="3 Liquidaciones Pendientes" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource MainForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Border Background="#202196f3" Padding="12" CornerRadius="10" BorderBrush="#2196f3" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="ℹ️" VerticalAlignment="Center"/>
                                <TextBlock Text="SQLite: Saludable" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource MainForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Border.metricCard">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BorderThickness" Value="0,6,0,0" />
            <Setter Property="BoxShadow" Value="0 8 20 0 #30000000" />
        </Style>
        
        <Style Selector="TextBlock.cardLabel">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <Style Selector="TextBlock.cardValue">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style Selector="Border.chartCard">
            <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="25" />
            <Setter Property="BoxShadow" Value="0 6 25 0 #20000000" />
        </Style>

        <Style Selector="ToggleButton.privacyButton">
            <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Width" Value="45" />
            <Setter Property="Height" Value="45" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarSeparatorBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}" 
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="ToggleButton.privacyButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarSeparatorBrush}" />
        </Style>
        
        <Style Selector="ToggleButton.privacyButton:checked">
            <Setter Property="Background" Value="#30ff5252" />
            <Setter Property="BorderBrush" Value="#ff5252" />
        </Style>

        <Style Selector="Button.alertButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>
</UserControl>
