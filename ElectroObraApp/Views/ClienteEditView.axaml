<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             x:Class="ElectroObraApp.Views.ClienteEditView"
             x:DataType="vm:ClienteEditViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.KeyBindings>
    <Border Padding="25" Background="#2d2d2d" CornerRadius="12" BoxShadow="0 4 10 0 #40000000" Width="600">
        <StackPanel Spacing="18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,5" Foreground="White"/>
            
            <StackPanel Spacing="5">
                <TextBlock Text="Nombre o Razón Social" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                <TextBox Text="{Binding Cliente.Nombre}" PlaceholderText="Ej: Electro S.A."/>
            </StackPanel>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="20" RowDefinitions="Auto, Auto" RowSpacing="15">
                <!-- Fila 1: CUIT y Condición IVA -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="CUIT" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <TextBox Text="{Binding Cliente.Cuit}" PlaceholderText="20-XXXXXXXX-X"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Condición IVA" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <TextBox Text="{Binding Cliente.CondicionIva}" PlaceholderText="Responsable Inscripto"/>
                </StackPanel>

                <!-- Fila 2: Teléfono y Email -->
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Teléfono" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <TextBox Text="{Binding Cliente.Telefono}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Email Principal" FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding Cliente.Email}"/>
                        <Button Grid.Column="1" Command="{Binding OpenEmailCommand}" 
                                Padding="8,4" Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center" ToolTip.Tip="Enviar Correo">
                            <PathIcon Data="M20,4H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V6C22,4.9,21.1,4,20,4z M20,18H4V8l8,5l8,-5V18z M12,11L4,6h16L12,11z" 
                                      Width="16" Height="16" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <Separator Background="#444" Margin="0,5"/>
            
            <StackPanel Spacing="10">
                <DockPanel>
                    <TextBlock Text="Otros Contactos / Emails" FontSize="13" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center"/>
                    <Button Content="+" Command="{Binding AddContactCommand}" HorizontalAlignment="Right" Width="28" Height="28" Padding="0" CornerRadius="14"/>
                </DockPanel>
                
                <ItemsControl ItemsSource="{Binding Cliente.Contactos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="120,*,Auto" Margin="0,2" ColumnSpacing="10">
                                <TextBox Grid.Column="0" Text="{Binding Etiqueta}" PlaceholderText="Etiqueta"/>
                                <TextBox Grid.Column="1" Text="{Binding Email}" PlaceholderText="Email"/>
                                <Button Grid.Column="2" Content="✕" Command="{Binding $parent[UserControl].((vm:ClienteEditViewModel)DataContext).RemoveContactCommand}" CommandParameter="{Binding}" Foreground="#e74c3c" Classes="link"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            
            <Separator Background="#444" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,10,0,0">
                <Button Content="Cancelar" Command="{Binding CancelCommand}" IsCancel="True" Padding="20,0"/>
                <Button Content="Guardar" Classes="accent" Command="{Binding SaveCommand}" IsDefault="True" Padding="20,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

