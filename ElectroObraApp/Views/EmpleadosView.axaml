<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ElectroObraApp.Views.EmpleadosView"
             x:DataType="vm:EmpleadosViewModel">
    <Grid>
        <DockPanel Margin="20" IsVisible="{Binding !IsEditing}">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <TextBlock Text="Empleados" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="Agregar" Classes="accent" Command="{Binding AddCommand}" />
                    <Button Content="Refrescar" Command="{Binding LoadEmpleadosCommand}" />
                </StackPanel>
            </Grid>

            <Border DockPanel.Dock="Top" Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#3d3d3d" BorderThickness="1">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource filter_regular}" Width="16" Height="16" Foreground="#aaa"/>
                            <TextBlock Text="FILTROS DE BÚSQUEDA" FontSize="12" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" HorizontalAlignment="Right" Content="Limpiar Filtros" Classes="link" Command="{Binding LimpiarFiltrosCommand}" FontSize="11"/>
                    </Grid>

                    <WrapPanel Orientation="Horizontal" Margin="-5">
                        <StackPanel Margin="5">
                            <TextBlock Text="Nombre / Cargo" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <TextBox Width="200" Text="{Binding FiltroNombre}" PlaceholderText="Buscar..."/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Estado" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <ComboBox Width="120" SelectedIndex="{Binding FiltroEstadoIndex}">
                                <ComboBoxItem Content="Todos"/>
                                <ComboBoxItem Content="Activos"/>
                                <ComboBoxItem Content="Inactivos"/>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
            
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                <TextBlock Text="Elementos por página:" VerticalAlignment="Center" FontSize="12" Foreground="#aaa"/>
                <ComboBox ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding PageSize}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource PageSizeConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Empleados}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      x:CompileBindings="False"
                      GridLinesVisibility="All"
                      DoubleTapped="OnDataGridDoubleTapped">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre, Mode=OneWay}" Width="*" />
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni, Mode=OneWay}" />
                    <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo, Mode=OneWay}" />
                    <DataGridTextColumn Header="Sueldo Base" Binding="{Binding SueldoBase, StringFormat=\{0:C\}, Mode=OneWay}" />
                    <DataGridTextColumn Header="Ingreso" Binding="{Binding FechaIngreso, StringFormat=\{0:dd/MM/yyyy\}, Mode=OneWay}" />
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo, Mode=OneWay}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Overlay de Edición -->
        <Border Background="#AA000000" IsVisible="{Binding IsEditing}" Focusable="True">
            <ContentControl Content="{Binding EditViewModel}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>

