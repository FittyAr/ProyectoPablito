<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ElectroObraApp.Views.MovimientosView"
             x:DataType="vm:MovimientosViewModel">
    <Grid>
        <DockPanel Margin="20" IsVisible="{Binding !IsEditing}">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <TextBlock Text="Gestión de Movimientos" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="Agregar" Classes="accent" Command="{Binding AddCommand}" />
                    <Button Content="Refrescar" Command="{Binding LoadMovimientosCommand}" />
                </StackPanel>
                
                <Button HorizontalAlignment="Right" Content="Exportar">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem Header="PDF (.pdf)" Command="{Binding ExportPdfCommand}" />
                            <MenuItem Header="Excel (.xlsx)" Command="{Binding ExportExcelCommand}" />
                            <MenuItem Header="Word (.docx)" Command="{Binding ExportWordCommand}" />
                            <MenuItem Header="CSV (.csv)" Command="{Binding ExportCsvCommand}" />
                            <MenuItem Header="JSON (.json)" Command="{Binding ExportJsonCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <Border DockPanel.Dock="Top" Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#3d3d3d" BorderThickness="1">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource filter_regular}" Width="16" Height="16" Foreground="#aaa"/>
                            <TextBlock Text="FILTROS DE BÚSQUEDA" FontSize="12" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" HorizontalAlignment="Right" Content="Limpiar Filtros" Classes="link" Command="{Binding LimpiarFiltrosCommand}" FontSize="11"/>
                    </Grid>
                    
                    <WrapPanel Orientation="Horizontal" Margin="-5">
                        <StackPanel Margin="5">
                            <TextBlock Text="Concepto" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <TextBox Width="180" Text="{Binding FiltroConcepto}" PlaceholderText="Buscar..."/>
                        </StackPanel>
                        
                        <StackPanel Margin="5">
                            <TextBlock Text="Tipo" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <ComboBox Width="140" 
                                      ItemsSource="{Binding TiposMovimiento}" 
                                      SelectedValue="{Binding FiltroTipoId}" 
                                      SelectedValueBinding="{Binding Id}" 
                                      DisplayMemberBinding="{Binding Nombre}"
                                      PlaceholderText="Seleccionar..."/>
                        </StackPanel>
                        
                        <StackPanel Margin="5">
                            <TextBlock Text="Fecha Desde" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <CalendarDatePicker SelectedDate="{Binding FiltroFechaDesde}" PlaceholderText="Desde" Width="140"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Fecha Hasta" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <CalendarDatePicker SelectedDate="{Binding FiltroFechaHasta}" PlaceholderText="Hasta" Width="140"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Monto Mín" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <NumericUpDown Width="110" Value="{Binding FiltroMontoMin}" FormatString="C0" PlaceholderText="Mín"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="Monto Máx" FontSize="10" Foreground="#aaa" Margin="0,0,0,4"/>
                            <NumericUpDown Width="110" Value="{Binding FiltroMontoMax}" FormatString="C0" PlaceholderText="Máx"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
            
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                <TextBlock Text="Elementos por página:" VerticalAlignment="Center" FontSize="12" Foreground="#aaa"/>
                <ComboBox ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding PageSize}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource PageSizeConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Movimientos}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      x:CompileBindings="False"
                      GridLinesVisibility="All"
                      DoubleTapped="OnDataGridDoubleTapped">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto, Mode=OneWay}" Width="*" />
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMovimientoNombre, Mode=OneWay}" />
                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=\{0:dd/MM/yyyy\}, Mode=OneWay}" />
                    <DataGridTextColumn Header="Monto" Binding="{Binding Monto, StringFormat=\{0:C\}, Mode=OneWay}" />
                    <DataGridTextColumn Header="Cant" Binding="{Binding Cantidad, Mode=OneWay}" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=\{0:C\}, Mode=OneWay}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Overlay de Edición -->
        <Border Background="#AA000000" IsVisible="{Binding IsEditing}" Focusable="True">
            <ContentControl Content="{Binding EditViewModel}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>

