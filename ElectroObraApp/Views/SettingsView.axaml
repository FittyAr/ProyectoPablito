<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="ElectroObraApp.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Configuración del Sistema" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource MainForegroundBrush}"/>
        
        <TabControl Grid.Row="1">
            <!-- General Tab -->
            <TabItem Header="General">
                <StackPanel Spacing="15" Margin="0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Nombre de la Aplicación" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <TextBox Text="{Binding AppName}" PlaceholderText="Ej: ElectroObraApp"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="5">
                        <TextBlock Text="Idioma Predeterminado" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Español (es)"/>
                            <ComboBoxItem Content="English (en)"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            
            <!-- Branding Tab -->
            <TabItem Header="Marca">
                <StackPanel Spacing="15" Margin="0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Ruta del Logo" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <TextBox Text="{Binding LogoPath}" PlaceholderText="avares://..."/>
                    </StackPanel>
                    
                    <StackPanel Spacing="5">
                        <TextBlock Text="Ruta del Fondo" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                        <TextBox Text="{Binding BackgroundPath}" PlaceholderText="avares://..."/>
                    </StackPanel>
                    
                    <TextBlock Text="Nota: Cambiar estas rutas requiere reiniciar la aplicación." 
                               FontStyle="Italic" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                </StackPanel>
            </TabItem>
            
            <!-- Appearance Tab -->
            <TabItem Header="Apariencia">
                <StackPanel Spacing="15" Margin="0,20">
                    <TextBlock Text="Seleccionar Tema" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                    <ListBox ItemsSource="{Binding Themes}" 
                             SelectedItem="{Binding SelectedTheme}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="{DynamicResource SidebarSeparatorBrush}" BorderThickness="1" CornerRadius="4" Margin="0,2">
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource MainForegroundBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <!-- Dashboard Tab -->
            <TabItem Header="Dashboard">
                <StackPanel Spacing="15" Margin="0,20">
                    <TextBlock Text="Preferencia de Visualización" FontWeight="Bold" Foreground="{DynamicResource MainForegroundBrush}"/>
                    <TextBlock Text="Define el periodo de tiempo predeterminado para los gráficos y métricas del dashboard." 
                               Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" TextWrapping="Wrap"/>
                    
                    <ListBox ItemsSource="{Binding DashboardPeriods}" 
                             SelectedItem="{Binding SelectedDashboardPeriod}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="{DynamicResource SidebarSeparatorBrush}" BorderThickness="1" CornerRadius="4" Margin="0,2">
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource MainForegroundBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <!-- Módulos Tab -->
            <TabItem Header="Módulos">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="0,20">
                        <!-- Email Section -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Correo Electrónico" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Cliente de correo preferido para enviar emails a clientes." 
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding EmailClients}" 
                                      SelectedItem="{Binding SelectedEmailClient}" 
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource SidebarSeparatorBrush}"/>

                        <!-- Settlements Section -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Liquidaciones" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Multiplicadores por defecto para días especiales." 
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                            
                            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" Margin="0,10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sábados:" VerticalAlignment="Center"/>
                                <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding MultiplierSaturday}" Increment="0.1" Minimum="0" FormatString="0.0"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Domingos:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MultiplierSunday}" Increment="0.1" Minimum="0" FormatString="0.0" Margin="0,10,0,0"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Feriados:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding MultiplierHoliday}" Increment="0.1" Minimum="0" FormatString="0.0" Margin="0,10,0,0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Guardar Cambios" 
                    Command="{Binding SaveCommand}"
                    Background="{DynamicResource AccentBrush}" 
                    Foreground="White" 
                    Padding="20,10"/>
        </StackPanel>
    </Grid>
</UserControl>
