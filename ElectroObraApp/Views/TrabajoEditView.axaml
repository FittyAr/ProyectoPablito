<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="ElectroObraApp.Views.TrabajoEditView"
             x:DataType="vm:TrabajoEditViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.KeyBindings>

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#ccc"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="ShowButtonSpinner" Value="False"/>
        </Style>
        <Style Selector="Border.certCard">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="BorderBrush" Value="#383838"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.colHead">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <!-- DockPanel raíz: header arriba, contenido llena el resto -->
    <DockPanel Background="#181818">

        <!-- ── HEADER ── -->
        <Border DockPanel.Dock="Top"
                Background="#1e1e1e"
                BorderBrush="#2a2a2a" BorderThickness="0,0,0,1"
                Padding="24,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Gestioná los datos generales y las certificaciones del trabajo"
                               FontSize="11" Foreground="#555" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Spacing="10" VerticalAlignment="Center">
                    <Button Content="Cancelar" Command="{Binding CancelCommand}"/>
                    <Button Content="💾  Guardar Trabajo"
                            Classes="accent" Command="{Binding SaveCommand}"
                            IsDefault="True" Padding="14,8"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── CUERPO: dos columnas — la izquierda es fija, la derecha llena el resto ── -->
        <!-- Grid de dos columnas; el DockPanel garantiza que este Grid tenga altura definida -->
        <Grid ColumnDefinitions="320,*">

            <!-- IZQUIERDA: Datos generales con scroll propio -->
            <ScrollViewer Grid.Column="0"
                          BorderBrush="#2a2a2a" BorderThickness="0,0,1,0">
                <StackPanel Spacing="14" Margin="20,16">

                    <TextBlock Classes="sectionTitle" Text="Datos Generales"/>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="CLIENTE *"/>
                        <ComboBox ItemsSource="{Binding Clientes}"
                                  SelectedValue="{Binding Trabajo.ClienteId}"
                                  SelectedValueBinding="{Binding Id}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Cliente al que pertenece este trabajo">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nombre}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="DESCRIPCIÓN *"/>
                        <TextBox Text="{Binding Trabajo.Descripcion}"
                                 PlaceholderText="Ej: Instalación eléctrica, renovación baño..."
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="75"
                                 ToolTip.Tip="Descripción del trabajo"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="PRESUPUESTO TOTAL"/>
                        <NumericUpDown Value="{Binding Trabajo.Presupuesto}"
                                       FormatString="C2" HorizontalAlignment="Stretch"
                                       ToolTip.Tip="Monto total presupuestado"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="FECHA INICIO"/>
                        <DatePicker SelectedDate="{Binding FechaInicioOffset}"
                                    HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Border Background="#252525" CornerRadius="5" Padding="12,10">
                        <CheckBox IsChecked="{Binding Trabajo.Finalizado}"
                                  Content="Trabajo Finalizado"
                                  ToolTip.Tip="Marcar cuando el trabajo esté terminado y cobrado"/>
                    </Border>

                    <Border Background="#161f16" CornerRadius="5" Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="💡 Certificaciones" FontSize="12" FontWeight="SemiBold" Foreground="#98c379"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666"
                                       Text="En la columna derecha podés agregar órdenes de trabajo o certificados de avance. Cada ítem tiene un % Anterior (ya certificado) y un % Actual (a certificar ahora)."/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- DERECHA: Certificaciones — DockPanel para que el scroll use TODO el alto restante -->
            <DockPanel Grid.Column="1">

                <!-- Sub-header certificaciones -->
                <Border DockPanel.Dock="Top"
                        Background="#1a1a1a"
                        BorderBrush="#2a2a2a" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Certificaciones / Órdenes de Trabajo"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#ccc"/>
                            <TextBlock FontSize="11" Foreground="#555"
                                       Text="Cada certificado representa un avance parcial. Usá Act% para indicar el avance del período."/>
                        </StackPanel>
                        <Button Content="＋ Agregar Certificado"
                                Command="{Binding AddOrdenCommand}"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Classes="accent"
                                ToolTip.Tip="Agrega un nuevo certificado de avance"/>
                    </DockPanel>
                </Border>

                <!-- ScrollViewer: el DockPanel le da el espacio restante garantizado -->
                <ScrollViewer Padding="16,12">
                    <StackPanel Spacing="0">

                        <ItemsControl ItemsSource="{Binding Trabajo.OrdenesTrabajo}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="certCard">
                                        <StackPanel Spacing="10">

                                            <!-- Título -->
                                            <Grid ColumnDefinitions="*,150,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding Titulo}"
                                                         PlaceholderText="Nombre del certificado (ej: Cert. Nº1 — Agosto)"
                                                         FontWeight="SemiBold"
                                                         ToolTip.Tip="Nombre de este certificado"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding NumeroCertificado}"
                                                         PlaceholderText="Número de certificado"
                                                         ToolTip.Tip="Número oficial"/>
                                                <Button Grid.Column="2"
                                                        Content="✕ Eliminar"
                                                        Command="{Binding $parent[UserControl].((vm:TrabajoEditViewModel)DataContext).RemoveOrdenCommand}"
                                                        CommandParameter="{Binding}"
                                                        Foreground="#e06c75" Background="Transparent"
                                                        BorderBrush="#e06c75" BorderThickness="1"
                                                        ToolTip.Tip="Eliminar esta certificación"/>
                                            </Grid>

                                            <!-- Tabla ítems -->
                                            <Border Background="#1a1a1a" CornerRadius="4" Padding="10,8">
                                                <StackPanel Spacing="3">
                                                    <!-- Cabecera columnas -->
                                                    <Grid ColumnDefinitions="*,70,55,100,55,55,70,34"
                                                          ColumnSpacing="4" Margin="2,0,2,4">
                                                        <TextBlock Classes="colHead" HorizontalAlignment="Left"
                                                                   Text="Descripción del Ítem"/>
                                                        <TextBlock Grid.Column="1" Classes="colHead" Text="Cantidad"/>
                                                        <TextBlock Grid.Column="2" Classes="colHead" Text="Unidad"/>
                                                        <TextBlock Grid.Column="3" Classes="colHead" Text="Precio Unit."/>
                                                        <TextBlock Grid.Column="4" Classes="colHead" Text="Ant %"
                                                                   ToolTip.Tip="% certificado en períodos anteriores"/>
                                                        <TextBlock Grid.Column="5" Classes="colHead" Text="Act %"
                                                                   Foreground="#abb2bf"
                                                                   ToolTip.Tip="% a certificar en este período"/>
                                                        <TextBlock Grid.Column="6" Classes="colHead" Text="Acum %"
                                                                   ToolTip.Tip="Total acumulado"/>
                                                    </Grid>

                                                    <Separator Background="#2a2a2a" Margin="0,0,0,3"/>

                                                    <!-- Filas -->
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="*,70,55,100,55,55,70,34"
                                                                      ColumnSpacing="4" Margin="0,2">
                                                                    <TextBox Text="{Binding Descripcion}"
                                                                             PlaceholderText="Descripción" FontSize="12"/>
                                                                    <NumericUpDown Grid.Column="1" Value="{Binding Cantidad}"
                                                                                   FontSize="12" ShowButtonSpinner="False"/>
                                                                    <TextBox Grid.Column="2" Text="{Binding Unidad}"
                                                                             FontSize="12"
                                                                             ToolTip.Tip="m², ml, gl, u..."/>
                                                                    <NumericUpDown Grid.Column="3" Value="{Binding PrecioUnitario}"
                                                                                   FormatString="C2" FontSize="12" ShowButtonSpinner="False"/>
                                                                    <NumericUpDown Grid.Column="4" Value="{Binding PorcentajeAnterior}"
                                                                                   Minimum="0" Maximum="100" FontSize="12"
                                                                                   ShowButtonSpinner="False"
                                                                                   Foreground="#555" IsReadOnly="True"
                                                                                   ToolTip.Tip="% anterior (automático)"/>
                                                                    <NumericUpDown Grid.Column="5" Value="{Binding PorcentajeActual}"
                                                                                   Minimum="0" Maximum="100" FontSize="12"
                                                                                   ShowButtonSpinner="False" FontWeight="SemiBold"
                                                                                   ToolTip.Tip="% de este período"/>
                                                                    <Border Grid.Column="6" Background="#1a2a1a"
                                                                            CornerRadius="3" VerticalAlignment="Center"
                                                                            Padding="6,4"
                                                                            ToolTip.Tip="Acumulado total">
                                                                        <TextBlock Text="{Binding PorcentajeAcumulado, StringFormat={}{0:N1}%}"
                                                                                   HorizontalAlignment="Center" FontSize="12"
                                                                                   Foreground="#98c379" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <Button Grid.Column="7" Content="✕"
                                                                            Command="{Binding $parent[UserControl].((vm:TrabajoEditViewModel)DataContext).RemoveItemCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Foreground="#e06c75" Background="Transparent"
                                                                            Padding="4,2" FontSize="12"
                                                                            ToolTip.Tip="Eliminar ítem"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Button Content="＋ Agregar Ítem"
                                                            Command="{Binding $parent[UserControl].((vm:TrabajoEditViewModel)DataContext).AddItemCommand}"
                                                            CommandParameter="{Binding}"
                                                            FontSize="11" HorizontalAlignment="Left"
                                                            Margin="0,6,0,0"
                                                            ToolTip.Tip="Agrega un ítem a este certificado"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Descuentos -->
                                            <Grid ColumnDefinitions="Auto,85,16,Auto,120"
                                                  ColumnSpacing="6" Margin="2,0,0,0">
                                                <TextBlock Text="Ajuste UOCRA (%):"
                                                           VerticalAlignment="Center" FontSize="12" Foreground="#888"
                                                           ToolTip.Tip="% ajuste UOCRA"/>
                                                <NumericUpDown Grid.Column="1" Value="{Binding AjusteUocraPorcentaje}"
                                                               ShowButtonSpinner="False"/>
                                                <TextBlock Grid.Column="2"/>
                                                <TextBlock Grid.Column="3" Text="Otros descuentos ($):"
                                                           VerticalAlignment="Center" FontSize="12" Foreground="#888"/>
                                                <NumericUpDown Grid.Column="4" Value="{Binding OtrosDescuentos}"
                                                               FormatString="C2" ShowButtonSpinner="False"/>
                                            </Grid>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Estado vacío -->
                        <Border IsVisible="{Binding !Trabajo.OrdenesTrabajo.Count}"
                                Background="#1e1e1e" CornerRadius="6" Padding="40" Margin="0,10">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Sin certificaciones aún"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#555" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hacé clic en '+ Agregar Certificado' para registrar el primer avance."
                                           FontSize="12" Foreground="#444" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="280"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Grid>

    </DockPanel>
</UserControl>

