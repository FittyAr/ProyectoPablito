<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ElectroObraApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ElectroObraApp.Views.MainView"
             x:DataType="vm:MainViewModel">
    
    <UserControl.Styles>
        <Style Selector="Button.menuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.menuItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarSeparatorBrush}" />
        </Style>
        <Style Selector="Button.active">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <SplitView IsPaneOpen="True"
               DisplayMode="CompactInline"
               OpenPaneLength="220"
               Background="{DynamicResource MainBackgroundBrush}"
               PaneBackground="{DynamicResource PaneBackgroundBrush}">
        <SplitView.Pane>
            <Grid RowDefinitions="Auto, Auto, *, Auto">
                <StackPanel Grid.Row="0" Spacing="5" Margin="5">
                    <Image Source="{Binding LogoImage}" 
                           Height="120" 
                           Margin="10,20" 
                           HorizontalAlignment="Center"/>
                    
                    <Separator Height="1" Background="{DynamicResource SidebarSeparatorBrush}" Margin="10,0,10,10"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Spacing="5" Margin="5">
                    <Button Command="{Binding NavigateToDashboardCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Dashboard}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Dashboard" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToMovimientosCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Movimientos}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Movimientos" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToClientesCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Clientes}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Clientes" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToEmpleadosCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Empleados}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Empleados" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToTrabajosCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Trabajos}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Trabajos" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToLiquidacionesCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Liquidaciones}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Liquidaciones" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSeedCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Seed}"
                            IsVisible="{Binding IsSeedEnabled}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Seed" Foreground="Orange"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom Button -->
                <StackPanel Grid.Row="3" Margin="5,0,5,10">
                    <Separator Height="1" Background="{DynamicResource SidebarSeparatorBrush}" Margin="10,0,10,10"/>
                    <Button Command="{Binding NavigateToSettingsCommand}" 
                            Classes="menuItem"
                            Classes.active="{Binding CurrentSection, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Configuración}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Configuración" Foreground="{DynamicResource MainForegroundBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </SplitView.Pane>

        <Grid>
            <!-- Background Image -->
            <Image Source="{Binding BackgroundImage}" 
                   Opacity="0.05" 
                   Stretch="Uniform" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
            
            <TransitioningContentControl Content="{Binding CurrentPage}" />
        </Grid>
    </SplitView>
</UserControl>

