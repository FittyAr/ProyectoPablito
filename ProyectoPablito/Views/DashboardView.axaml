<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ProyectoPablito.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ProyectoPablito.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="25">
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#eee" />
            
            <UniformGrid Columns="3" Height="150">
                <!-- Ingresos -->
                <Border Background="#1b3a1b" CornerRadius="12" Margin="5" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total Ingresos" FontSize="14" Foreground="#aaa"/>
                        <TextBlock Text="{Binding TotalIngresos, StringFormat=\{0:C\}}" FontSize="22" FontWeight="Bold" Foreground="#4caf50"/>
                    </StackPanel>
                </Border>

                <!-- Gastos -->
                <Border Background="#3a1b1b" CornerRadius="12" Margin="5" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total Gastos" FontSize="14" Foreground="#aaa"/>
                        <TextBlock Text="{Binding TotalGastos, StringFormat=\{0:C\}}" FontSize="22" FontWeight="Bold" Foreground="#f44336"/>
                    </StackPanel>
                </Border>

                <!-- Balance -->
                <Border Background="#1b1b3a" CornerRadius="12" Margin="5" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Balance Neto" FontSize="14" Foreground="#aaa"/>
                        <TextBlock Text="{Binding Balance, StringFormat=\{0:C\}}" FontSize="22" FontWeight="Bold" Foreground="#2196f3"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Resumen de Actividad Reciente" FontSize="20" FontWeight="SemiBold" Margin="0,20,0,0" />
            <TextBlock Text="Aquí se mostrarán los próximos vencimientos y alertas." Foreground="#888" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
