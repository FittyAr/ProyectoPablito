<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ProyectoPablito.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
             x:Class="ProyectoPablito.Views.TrabajoEditView"
             x:DataType="vm:TrabajoEditViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.KeyBindings>
    <Border Padding="20" Background="#2d2d2d" CornerRadius="8">
        <StackPanel Spacing="15">
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Spacing="5">
                <TextBlock Text="Cliente" FontSize="12" Foreground="#aaa"/>
                <ComboBox ItemsSource="{Binding Clientes}" 
                          SelectedValue="{Binding Trabajo.ClienteId}"
                          SelectedValueBinding="{Binding Id}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nombre}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Descripción" FontSize="12" Foreground="#aaa"/>
                <TextBox Text="{Binding Trabajo.Descripcion}" PlaceholderText="Breve descripción del trabajo" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,5,0">
                    <TextBlock Text="Presupuesto" FontSize="12" Foreground="#aaa"/>
                    <NumericUpDown Value="{Binding Trabajo.Presupuesto}" FormatString="C2"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5" Margin="5,0,0,0">
                    <TextBlock Text="Fecha Inicio" FontSize="12" Foreground="#aaa"/>
                    <DatePicker SelectedDate="{Binding FechaInicioOffset}"/>
                </StackPanel>
            </Grid>

            <CheckBox IsChecked="{Binding Trabajo.Finalizado}" Content="Trabajo Finalizado"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Cancelar" Command="{Binding CancelCommand}" />
                <Button Content="Guardar" Classes="accent" Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
