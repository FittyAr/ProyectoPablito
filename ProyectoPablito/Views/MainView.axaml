<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProyectoPablito.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ProyectoPablito.Views.MainView"
             x:DataType="vm:MainViewModel">
    
    <SplitView IsPaneOpen="True"
               DisplayMode="CompactInline"
               OpenPaneLength="200"
               Background="#1e1e1e"
               PaneBackground="#252526">
        <SplitView.Pane>
            <StackPanel Spacing="5" Margin="5">
                <TextBlock Text="{Binding Greeting}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Margin="10,20" 
                           Foreground="White"/>
                
                <Button Command="{Binding NavigateToDashboardCommand}" HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Dashboard" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToMovimientosCommand}" HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Movimientos" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToClientesCommand}" HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Clientes" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToEmpleadosCommand}" HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Empleados" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToTrabajosCommand}" HorizontalAlignment="Stretch" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Trabajos" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToSeedCommand}" HorizontalAlignment="Stretch" Background="Transparent" IsVisible="{Binding IsSeedEnabled}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Seed" Foreground="Orange"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </SplitView.Pane>

        <TransitioningContentControl Content="{Binding CurrentPage}" />
    </SplitView>
</UserControl>
